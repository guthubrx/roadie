#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
label="com.roadie.roadied"
plist="$HOME/Library/LaunchAgents/$label.plist"
log_dir="$HOME/.roadies"
runtime_bin_dir="$repo_root/bin"
local_bin_dir="$HOME/.local/bin"
pidfile="$log_dir/roadied.pid"
control_center_pidfile="$log_dir/roadie-control-center.pid"
tmux_session="roadied"
control_center_tmux_session="roadie-control-center"
start_control_center=0

for arg in "$@"; do
  case "$arg" in
    --control-center)
      start_control_center=1
      ;;
    --no-control-center)
      start_control_center=0
      ;;
    *)
      echo "usage: $0 [--control-center|--no-control-center]" >&2
      exit 64
      ;;
  esac
done

mkdir -p "$log_dir" "$HOME/Library/LaunchAgents" "$runtime_bin_dir" "$local_bin_dir"
: > "$log_dir/roadied.stdout.log"
: > "$log_dir/roadied.stderr.log"
if [[ "$start_control_center" -eq 1 ]]; then
  : > "$log_dir/roadie-control-center.stdout.log"
  : > "$log_dir/roadie-control-center.stderr.log"
fi

"$script_dir/with-xcode" swift build --configuration debug --product roadied
"$script_dir/with-xcode" swift build --configuration debug --product roadie
bin_dir="$("$script_dir/with-xcode" swift build --show-bin-path --configuration debug)"
build_bin="$bin_dir/roadied"
build_cli="$bin_dir/roadie"
roadied_bin="$runtime_bin_dir/roadied"
roadie_bin="$runtime_bin_dir/roadie"
local_roadied_bin="$local_bin_dir/roadied"
local_roadie_bin="$local_bin_dir/roadie"

if [[ ! -x "$build_bin" ]]; then
  echo "roadied binary not found: $build_bin" >&2
  exit 1
fi
if [[ ! -x "$build_cli" ]]; then
  echo "roadie binary not found: $build_cli" >&2
  exit 1
fi
cp "$build_bin" "$roadied_bin"
cp "$build_cli" "$roadie_bin"
cp "$build_bin" "$local_roadied_bin"
cp "$build_cli" "$local_roadie_bin"
chmod +x "$roadied_bin"
chmod +x "$roadie_bin" "$local_roadied_bin" "$local_roadie_bin"
codesign --force --sign - "$roadied_bin" >/dev/null 2>&1 || true
codesign --force --sign - "$roadie_bin" >/dev/null 2>&1 || true
codesign --force --sign - "$local_roadied_bin" >/dev/null 2>&1 || true
codesign --force --sign - "$local_roadie_bin" >/dev/null 2>&1 || true

cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$label</string>
  <key>ProgramArguments</key>
  <array>
    <string>$roadied_bin</string>
    <string>run</string>
    <string>--yes</string>
  </array>
  <key>WorkingDirectory</key>
  <string>$repo_root</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$log_dir/roadied.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>$log_dir/roadied.stderr.log</string>
</dict>
</plist>
PLIST

if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
  launchctl bootout "gui/$(id -u)/$label" >/dev/null 2>&1 || true
fi

if [[ -f "$pidfile" ]]; then
  old_pid="$(cat "$pidfile")"
  if ps -p "$old_pid" -o args= 2>/dev/null | grep -q "$roadied_bin run --yes"; then
    kill "$old_pid" >/dev/null 2>&1 || true
    sleep 1
  fi
  rm -f "$pidfile"
fi

if [[ -f "$control_center_pidfile" ]]; then
  old_control_center_pid="$(cat "$control_center_pidfile")"
  if ps -p "$old_control_center_pid" -o args= 2>/dev/null | grep -q "$roadied_bin control-center"; then
    kill "$old_control_center_pid" >/dev/null 2>&1 || true
    sleep 1
  fi
  rm -f "$control_center_pidfile"
fi

if command -v tmux >/dev/null 2>&1; then
  tmux kill-session -t "$tmux_session" >/dev/null 2>&1 || true
  tmux new-session -d -s "$tmux_session" "cd '$repo_root' && exec '$roadied_bin' run --yes >> '$log_dir/roadied.stdout.log' 2>> '$log_dir/roadied.stderr.log'"
  pid="$(tmux list-panes -t "$tmux_session" -F '#{pane_pid}')"
  echo "$pid" > "$pidfile"
  tmux kill-session -t "$control_center_tmux_session" >/dev/null 2>&1 || true
  if [[ "$start_control_center" -eq 1 ]]; then
    tmux new-session -d -s "$control_center_tmux_session" "cd '$repo_root' && exec '$roadied_bin' control-center >> '$log_dir/roadie-control-center.stdout.log' 2>> '$log_dir/roadie-control-center.stderr.log'"
    control_center_pid="$(tmux list-panes -t "$control_center_tmux_session" -F '#{pane_pid}')"
    echo "$control_center_pid" > "$control_center_pidfile"
  fi
else
  (
    cd "$repo_root"
    nohup "$roadied_bin" run --yes >> "$log_dir/roadied.stdout.log" 2>> "$log_dir/roadied.stderr.log" < /dev/null &
    echo "$!" > "$pidfile"
    if [[ "$start_control_center" -eq 1 ]]; then
      nohup "$roadied_bin" control-center >> "$log_dir/roadie-control-center.stdout.log" 2>> "$log_dir/roadie-control-center.stderr.log" < /dev/null &
      echo "$!" > "$control_center_pidfile"
    fi
  )
fi

sleep 1
pid="$(cat "$pidfile")"
if ! ps -p "$pid" >/dev/null 2>&1; then
  echo "roadied failed to start; logs: $log_dir/roadied.stderr.log" >&2
  exit 1
fi

echo "roadied started"
echo "pid: $pid"
if [[ -f "$control_center_pidfile" ]] && ps -p "$(cat "$control_center_pidfile")" >/dev/null 2>&1; then
  echo "control center started"
  echo "control center pid: $(cat "$control_center_pidfile")"
else
  echo "control center disabled"
fi
echo "plist: $plist"
echo "logs: $log_dir/roadied.stdout.log $log_dir/roadied.stderr.log"
