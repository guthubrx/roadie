#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
label="com.roadie.roadied"
plist="$HOME/Library/LaunchAgents/$label.plist"
log_dir="$HOME/.roadies"
runtime_bin_dir="$repo_root/bin"
pidfile="$log_dir/roadied.pid"
tmux_session="roadied"

mkdir -p "$log_dir" "$HOME/Library/LaunchAgents" "$runtime_bin_dir"
: > "$log_dir/roadied.stdout.log"
: > "$log_dir/roadied.stderr.log"

"$script_dir/with-xcode" swift build --configuration debug --product roadied
bin_dir="$("$script_dir/with-xcode" swift build --show-bin-path --configuration debug)"
build_bin="$bin_dir/roadied"
roadied_bin="$runtime_bin_dir/roadied"

if [[ ! -x "$build_bin" ]]; then
  echo "roadied binary not found: $build_bin" >&2
  exit 1
fi
cp "$build_bin" "$roadied_bin"
chmod +x "$roadied_bin"
codesign --force --sign - "$roadied_bin" >/dev/null 2>&1 || true

cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$label</string>
  <key>ProgramArguments</key>
  <array>
    <string>$roadied_bin</string>
    <string>run</string>
    <string>--yes</string>
  </array>
  <key>WorkingDirectory</key>
  <string>$repo_root</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$log_dir/roadied.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>$log_dir/roadied.stderr.log</string>
</dict>
</plist>
PLIST

if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
  launchctl bootout "gui/$(id -u)/$label" >/dev/null 2>&1 || true
fi

if [[ -f "$pidfile" ]]; then
  old_pid="$(cat "$pidfile")"
  if ps -p "$old_pid" -o args= 2>/dev/null | grep -q "$roadied_bin run --yes"; then
    kill "$old_pid" >/dev/null 2>&1 || true
    sleep 1
  fi
  rm -f "$pidfile"
fi

if command -v tmux >/dev/null 2>&1; then
  tmux kill-session -t "$tmux_session" >/dev/null 2>&1 || true
  tmux new-session -d -s "$tmux_session" "cd '$repo_root' && exec '$roadied_bin' run --yes >> '$log_dir/roadied.stdout.log' 2>> '$log_dir/roadied.stderr.log'"
  pid="$(tmux list-panes -t "$tmux_session" -F '#{pane_pid}')"
  echo "$pid" > "$pidfile"
else
  (
    cd "$repo_root"
    nohup "$roadied_bin" run --yes >> "$log_dir/roadied.stdout.log" 2>> "$log_dir/roadied.stderr.log" < /dev/null &
    echo "$!" > "$pidfile"
  )
fi

sleep 1
pid="$(cat "$pidfile")"
if ! ps -p "$pid" >/dev/null 2>&1; then
  echo "roadied failed to start; logs: $log_dir/roadied.stderr.log" >&2
  exit 1
fi

echo "roadied started"
echo "pid: $pid"
echo "plist: $plist"
echo "logs: $log_dir/roadied.stdout.log $log_dir/roadied.stderr.log"
