#!/usr/bin/env bash
set -euo pipefail

label="com.roadie.roadied"
pidfile="$HOME/.roadies/roadied.pid"

if [[ -f "$pidfile" ]]; then
  pid="$(cat "$pidfile")"
  if ps -p "$pid" -o args= 2>/dev/null | grep -q 'roadied run --yes'; then
    echo "roadied running"
    echo "pid: $pid"
    exit 0
  fi
  echo "roadied pidfile stale: $pidfile"
fi

if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
  echo "$label loaded"
  launchctl print "gui/$(id -u)/$label" | sed -n '1,80p'
else
  echo "$label not loaded"
  exit 3
fi
